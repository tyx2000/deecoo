# Required: DeepSeek API key from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# Deecoo request defaults.
DEECOO_BASE_URL=https://api.deepseek.com
DEECOO_MODEL=deepseek-v4-pro

# Optional request/agent controls.
DEECOO_MAX_TOKENS=4096
DEECOO_TIMEOUT_MS=120000
DEECOO_API_RETRIES=5
DEECOO_PERMISSION_MODE=ask-once
DEECOO_THEME=tokyo-night
# Optional DeepSeek reasoning controls. Leave unset if your selected model does not support them.
# DEECOO_REASONING_EFFORT=high
# DEECOO_THINKING=enabled

# Optional: default workspace if --cwd is not passed.
# DEECOO_CWD=/absolute/path/to/project
