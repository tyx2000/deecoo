# Required: DeepSeek API key from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# DeepCode request defaults.
DEEPCODE_BASE_URL=https://api.deepseek.com
DEEPCODE_MODEL=deepseek-v4-pro

# Optional request/agent controls.
DEEPCODE_MAX_STEPS=20
DEEPCODE_MAX_TOKENS=4096
DEEPCODE_TIMEOUT_MS=120000
DEEPCODE_API_RETRIES=5
DEEPCODE_PERMISSION_MODE=ask-once
DEEPCODE_THEME=tokyo-night
# Optional DeepSeek reasoning controls. Leave unset if your selected model does not support them.
# DEEPCODE_REASONING_EFFORT=high
# DEEPCODE_THINKING=enabled

# Optional: default workspace if --cwd is not passed.
# DEEPCODE_CWD=/absolute/path/to/project
